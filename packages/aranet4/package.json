{
  "name": "@whois-homebridge/homebridge-aranet4",
  "version": "0.2.1",
  "description": "Homebridge plugin for Aranet4 CO2/environment sensor via passive BLE scanning with Eve history support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/whoiscadenyoung/homebridge-plugins#readme",
  "files": [
    "dist/",
    "config.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src/ --config eslint.config.mjs",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "test": "jest --config jest.config.js --verbose",
    "test:coverage": "jest --config jest.config.js --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoiscadenyoung/homebridge-plugins.git"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "dependencies": {
    "@stoprocent/noble": "^2.4.0",
    "fakegato-history": "^0.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "homebridge": "^1.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  }
}
