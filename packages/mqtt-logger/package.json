{
  "displayName": "Homebridge MQTT Logger",
  "name": "@whois-homebridge/homebridge-mqtt-logger",
  "version": "0.1.0",
  "description": "Homebridge plugin that embeds an MQTT broker and routes sensor readings to Supabase.",
  "license": "MIT",
  "homepage": "https://github.com/whoiscadenyoung/homebridge-plugins#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoiscadenyoung/homebridge-plugins.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "config.schema.json",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint src/ --config eslint.config.mjs",
    "watch": "npm run build && npm link && nodemon",
    "build": "rm -rf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge"
  ],
  "dependencies": {
    "aedes": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@eslint/js": "^9.0.0",
    "homebridge": "^1.8.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
