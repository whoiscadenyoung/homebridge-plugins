{
  "displayName": "Homebridge Airmega IoCare+",
  "name": "@whois-homebridge/homebridge-airmega",
  "version": "0.3.1",
  "description": "Homebridge plugin for Coway Airmega purifiers (400S verified; 300S / 250S / MightyS / IconS share the IoCare+ API).",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/whoiscadenyoung/homebridge-plugins#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoiscadenyoung/homebridge-plugins.git"
  },
  "main": "dist/index.js",
  "icon": "icon.png",
  "files": [
    "dist/",
    "config.schema.json",
    "icon.png",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint src/ --config eslint.config.mjs",
    "watch": "npm run build && npm link && nodemon",
    "build": "rm -rf ./dist && tsc",
    "test": "bun test test/",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge"
  ],
  "dependencies": {
    "axios": "^1.18.1",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^24.0.0",
    "@eslint/js": "^9.0.0",
    "homebridge": "^1.8.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
