{
  "pluginAlias": "AirmegaPlatform",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Airmega",
        "required": true
      },
      "username": {
        "title": "IoCare+ Username",
        "description": "Your IoCare+ login — email address or phone number.",
        "type": "string",
        "required": true,
        "maxLength": 256
      },
      "password": {
        "title": "IoCare+ Password",
        "type": "string",
        "required": true,
        "maxLength": 256,
        "x-schema-form": { "type": "password" }
      },
      "skipPasswordChange": {
        "title": "Skip 60-day password change prompt",
        "type": "boolean",
        "default": true,
        "description": "Coway forces password rotation every 60 days. Leave true to defer; set false to be re-prompted via reauth."
      },
      "pollingInterval": {
        "title": "Polling interval (seconds)",
        "type": "integer",
        "default": 60,
        "minimum": 30
      },
      "exposeLight": {
        "title": "Expose LED display as a switch",
        "type": "boolean",
        "default": true
      },
      "supabase": {
        "title": "Supabase",
        "type": "object",
        "properties": {
          "url": {
            "title": "Project URL",
            "type": "string",
            "placeholder": "https://yourproject.supabase.co"
          },
          "key": {
            "title": "Secret API Key",
            "type": "string",
            "placeholder": "your-service-role-key",
            "secret": true
          }
        }
      }
    }
  }
}
